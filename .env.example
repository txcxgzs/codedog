# ========================================
# 编程狗社区 - 环境配置示例
# 复制此文件为 .env 并修改配置
# ========================================

# 服务端口配置
SERVER_PORT=3001

# 数据库配置
# 可选值: sqlite, mysql
# sqlite: 轻量级，无需额外安装，适合小型部署
# mysql: 性能更好，适合生产环境
DB_TYPE=sqlite

# SQLite 数据库文件路径
# 本地/宝塔部署: ./data/database.sqlite (相对于 server/ 工作目录)
# Docker 部署: 由 docker-compose.yml 自动设置,此处值被覆盖
DB_PATH=./data/database.sqlite

# MySQL配置（当DB_TYPE=mysql时使用）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=coding_dog
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT配置（必须修改！部署脚本会自动生成）
# 请使用至少64位的随机字符串
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Session配置（生产环境必填，至少32字符随机字符串，可用 openssl rand -hex 32 生成）
# 留空时生产环境会启动失败，部署脚本会自动生成
SESSION_SECRET=

# CORS配置（生产环境设置，多个域名用逗号分隔）
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# 独立即时通讯系统（运行 im-system/scripts/keygen.js 后启用）
# IM_PUBLIC_URL=https://im.yourdomain.com/im
# IM_SSO_PRIVATE_KEY_FILE=/absolute/path/to/im_sso_private.pem
# Docker 部署可改用私钥 PEM 的 Base64（不要提交到 Git）
# IM_SSO_PRIVATE_KEY_BASE64=

# 极验验证码配置（可选）
# 注册地址: https://www.geetest.com/
GEETEST_ID=
GEETEST_KEY=

# hCaptcha配置（可选）
# 注册地址: https://www.hcaptcha.com/
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
