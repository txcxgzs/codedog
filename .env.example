# ========================================
# 编程狗社区 - 环境配置示例
# 复制此文件为 .env 并修改配置
# ========================================

# 服务端口配置
SERVER_PORT=3001

# 数据库配置
# 可选值: sqlite, mysql
# sqlite: 轻量级，无需额外安装，适合小型部署
# mysql: 性能更好，适合生产环境
DB_TYPE=sqlite

# MySQL配置（当DB_TYPE=mysql时使用）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=coding_dog
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT配置（必须修改！部署脚本会自动生成）
# 请使用至少64位的随机字符串
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Session配置（建议设置，且长度>=32位）
SESSION_SECRET=your-session-secret-key-at-least-32-chars

# CORS配置（生产环境设置，多个域名用逗号分隔）
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# 极验验证码配置（可选）
# 注册地址: https://www.geetest.com/
GEETEST_ID=
GEETEST_KEY=

# hCaptcha配置（可选）
# 注册地址: https://www.hcaptcha.com/
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
