# 服务端口配置
# 优先读取 PORT（兼容容器/云平台），其次 SERVER_PORT
PORT=3001
NODE_ENV=development

# 数据库配置 (SQLite - 默认)
DB_TYPE=sqlite

# 数据库配置 (MySQL - 可选)
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=coding_dog
# DB_USER=root
# DB_PASSWORD=your_password

# JWT密钥 (生产环境必填，至少32字符随机字符串，可用 openssl rand -hex 32 生成)
# 留空时生产环境会启动失败，部署脚本会自动生成
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Session密钥 (生产环境必填，至少32字符随机字符串，可用 openssl rand -hex 32 生成)
SESSION_SECRET=

# CORS配置 (生产环境必填，多个域名用逗号分隔，例如: https://yourdomain.com)
CORS_ORIGIN=

# 极验验证码配置 (可选)
# 注册地址: https://www.geetest.com/
GEETEST_ID=
GEETEST_KEY=

# hCaptcha配置 (可选)
# 注册地址: https://www.hcaptcha.com/
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# 代理配置 (可选，解决服务器IP被编程猫封禁问题)
# 如果你的服务器无法访问编程猫API，请配置代理
# HTTP代理格式: http://IP:端口 或 http://用户名:密码@IP:端口
# SOCKS5代理格式: socks5://IP:端口
HTTPS_PROXY=
# HTTP_PROXY=
# ALL_PROXY=
